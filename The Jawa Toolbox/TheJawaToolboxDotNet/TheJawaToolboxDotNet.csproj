    <Reference Include="UtinniCoreDotNet">
      <!-- Use $(Configuration) so Release|x86, Debug|x86, and RelWithDbgInfo|x86
           builds each pick up the matching Utinni build output instead of always
           hard-binding to RelWithDbgInfo. Pre-fix, building TJT Release|x86 failed
           with CS0246 (UtinniCore / UtinniCoreDotNet namespaces missing) unless
           you had also built Utinni RelWithDbgInfo|x86 beforehand. -->
      <HintPath>..\..\..\Utinni\bin\$(Configuration)\UtinniCoreDotNet.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- 14-01: UtinniCoreDotNet.Saving.LooseOverridePath PHYSICALLY lives in the
         netstandard2.0 UtinniCoreDotNet.PathContainment assembly; the net472
         UtinniCoreDotNet.dll only [TypeForwardedTo]s it. With <Private>False</Private>
         on the UtinniCoreDotNet reference above, RAR does not auto-pull the
         forwarded-to implementation assembly into the C# compiler's reference set,
         so the forwarded LooseOverridePath fails to resolve (CS0103) in the
         Save-target files. Reference it explicitly so the compiler can follow the
         type-forward. CopyLocal=false: the framework build already copies it next to
         UtinniCoreDotNet.dll in Utinni\bin\$(Configuration)\. -->
    <Reference Include="UtinniCoreDotNet.PathContainment">
      <HintPath>..\..\..\Utinni\bin\$(Configuration)\UtinniCoreDotNet.PathContainment.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
